{
  "name": "core-guardian",
  "main": "src/_worker.ts",
  "compatibility_date": "2026-05-25",
  "compatibility_flags": ["nodejs_compat"],
  "upload_source_maps": true,
  "workers_dev": true,
  "preview_urls": true,
  // Core Guardian usage evaluation. Hourly, aligned with the GraphQL Analytics
  // hourly aggregation buckets; hourly crons also get the 15-minute CPU limit
  // rather than the 30-second request limit.
  "triggers": {
    "crons": ["0 * * * *"],
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "run_worker_first": true,
    "not_found_handling": "404-page",
  },
  "ai": {
    "binding": "AI",
    // Workers AI has no local emulation. `remote: true` lets `wrangler dev`
    // (which runs Durable Objects locally — `--remote` is unsupported for DOs)
    // proxy AI inference to the real Workers AI service, so the chat agents
    // stream genuine model output during local development.
    "remote": true,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CODE_MODE_AGENT",
        "class_name": "CodeModeAgent",
      },
      {
        "name": "BROWSER_HITL_AGENT",
        "class_name": "BrowserHitlAgent",
      },
      {
        "name": "WORKFLOWS_AGENT",
        "class_name": "WorkflowsAgent",
      },
      {
        "name": "ARTIFACT_AGENT",
        "class_name": "ArtifactAgent",
      },
      {
        "name": "CHAT_BROKER",
        "class_name": "ChatBroker",
      },
      {
        "name": "NOTIFICATIONS_AGENT",
        "class_name": "NotificationsAgent",
      },
      {
        "name": "ORCHESTRATOR_AGENT",
        "class_name": "OrchestratorAgent",
      },
      {
        "name": "RESEARCHER_AGENT",
        "class_name": "ResearcherAgent",
      },
      {
        "name": "CODER_AGENT",
        "class_name": "CoderAgent",
      },
      {
        "name": "MCP_AGENT",
        "class_name": "McpAgent",
      },
      {
        "name": "THINKING_AGENT",
        "class_name": "ThinkingAgent",
      },
      {
        "name": "SKILLS_AGENT",
        "class_name": "SkillsAgent",
      },
    ],
  },
  "browser": {
    "binding": "MYBROWSER",
  },
  "worker_loaders": [
    { "binding": "WORKER_LOADERS" }
  ],
  // Durable Object migrations.
  //
  // This Worker had never been deployed when these were first applied, so the
  // inherited v1/v2/v3 template history (which created, deleted, then re-created
  // OrchestratorAgent, and referenced a GoogleDocsAgent this codebase does not
  // export) described a lineage that never existed — and Cloudflare rejects a
  // delete-class migration for a class no previously-uploaded version exported.
  // Collapsed to a single v1 that creates exactly the classes src/_worker.ts
  // exports today. THIS IS NOW IMMUTABLE: the Worker has shipped under it, so
  // add new tags additively rather than editing v1.
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "CodeModeAgent",
        "BrowserHitlAgent",
        "WorkflowsAgent",
        "ArtifactAgent",
        "ChatBroker",
        "NotificationsAgent",
        "OrchestratorAgent",
        "ResearcherAgent",
        "CoderAgent",
        "McpAgent",
        "ThinkingAgent",
        "SkillsAgent",
      ],
    },
  ],
  // ---------------------------------------------------------------------------
  // Cloudflare Email Routing (inbound) — the `/inbox` showcase
  // ---------------------------------------------------------------------------
  //
  // RECEIVING email needs NO wrangler binding. The Worker exports an
  // `email(message, env, ctx)` handler (see src/_worker.ts +
  // src/backend/email/inbound.ts); Cloudflare invokes it when a Routing Rule
  // points an incoming address at this Worker. Set that up out-of-band:
  //
  //   Dashboard → the zone → Email → Email Routing →
  //     1. Enable Email Routing for the domain (adds the required MX + TXT/SPF).
  //     2. Routing Rules → "Send to a Worker" → select this Worker
  //        (core-guardian), or use a catch-all rule.
  //   …or via CLI:
  //     npx wrangler email routing rules create \
  //       --match "to=demo@yourdomain.com" --action worker \
  //       --value core-guardian
  //
  // FORWARDING a copy via `message.forward(INBOX_FORWARD_TO)` is optional. The
  // destination must be VERIFIED first (Dashboard → Destination addresses, or
  // `npx wrangler email routing addresses create you@gmail.com`). Leave
  // INBOX_FORWARD_TO empty to disable forwarding.
  //
  // REPLYING/SENDING (not used by this showcase) WOULD need a binding:
  //   "send_email": [{ "name": "EMAIL" }]
  // plus `npx wrangler email sending enable yourdomain.com`. Add it only if you
  // wire an outbound reply flow.
  "vars": {
    // Canonical public origin for this Worker. Use this instead of hardcoding
    // the host anywhere in backend code or scripts.
    "WORKER_BASE_URL": "https://core-guardian.hacolby.workers.dev",
    "AI_GATEWAY_ID": "default-gateway",
    "MODEL_CHAT": "@cf/openai/gpt-oss-120b",
    "MODEL_EXTRACT": "@cf/openai/gpt-oss-120b",
    "MODEL_DRAFT": "@cf/openai/gpt-oss-120b",
    "MODEL_TRANSCRIBE": "@cf/openai/whisper-large-v3-turbo",
    "DEFAULT_MODEL_EMBEDDING": "@cf/baai/bge-large-en-v1.5",
    // Optional verified destination for message.forward() in the email handler.
    // Empty string = forwarding disabled (the message is stored in D1 only).
    "INBOX_FORWARD_TO": "",
  },
  "kv_namespaces": [
    {
      // Astro's session driver injects a `SESSION` binding with no id, which
      // makes wrangler try to provision one on every deploy and collide with
      // the namespace it already created. Pin the existing namespace instead.
      "binding": "SESSION",
      "id": "13e88a55a4d04ef8aa15cc65e9f80dc8",
    },
    {
      "binding": "SESSIONS",
      "id": "aba8552a49c64335ba4832d34ce9459d",
      "remote": true,
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "core-guardian",
      "database_id": "d555f8ce-77c9-4c82-be80-de95b8d9c003",
      "migrations_dir": "drizzle",
    },
  ],
  "secrets_store_secrets": [
    {
      "binding": "GITHUB_TOKEN",
      "store_id": "8c42fa70938644e0a8a109744467375f",
      "secret_name": "GH_TOKEN",
    },
    {
      "binding": "CLOUDFLARE_ACCOUNT_ID",
      "store_id": "8c42fa70938644e0a8a109744467375f",
      "secret_name": "CLOUDFLARE_ACCOUNT_ID",
    },
    {
      "binding": "CLOUDFLARE_WRANGLER_API_TOKEN",
      "store_id": "8c42fa70938644e0a8a109744467375f",
      "secret_name": "CLOUDFLARE_WRANGLER_API_TOKEN",
    },
    {
      "binding": "WORKER_API_KEY",
      "store_id": "8c42fa70938644e0a8a109744467375f",
      "secret_name": "WORKER_API_KEY",
    },
    {
      "binding": "AI_GATEWAY_TOKEN",
      "store_id": "8c42fa70938644e0a8a109744467375f",
      "secret_name": "CLOUDFLARE_AI_GATEWAY_TOKEN",
    },
    {
      "binding": "GOOGLE_CREDS_SA_PRIVATE_KEY_PT_1",
      "store_id": "8c42fa70938644e0a8a109744467375f",
      "secret_name": "GOOGLE_CREDS_SA_PRIVATE_KEY_PT_1",
    },
    {
      "binding": "GOOGLE_CREDS_SA_PRIVATE_KEY_PT_2",
      "store_id": "8c42fa70938644e0a8a109744467375f",
      "secret_name": "GOOGLE_CREDS_SA_PRIVATE_KEY_PT_2",
    },
    {
      "binding": "GOOGLE_CREDS_SA_CLIENT_EMAIL",
      "store_id": "8c42fa70938644e0a8a109744467375f",
      "secret_name": "GOOGLE_CREDS_SA_CLIENT_EMAIL",
    },
  ],
  "r2_buckets": [
    {
      "binding": "R2_AUDIO_BUCKET",
      "bucket_name": "core-guardian-audio",
      "remote": true,
    },
    {
      "bucket_name": "core-guardian-files",
      "binding": "R2_FILES_BUCKET",
      "remote": true,
    },
  ],
}
