{
  "name": "core-guardian",
  "version": "26.06.24",
  "description": "The template helps you build apps with Astro, Tailwind CSS, and shadcn/ui.",
  "license": "MIT",
  "author": {
    "name": "126colby",
    "url": "https://github.com/126colby"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmbish04/core-guardian.git"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "start": "astro dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate",
    "migrate:local": "pnpm run db:generate && npx wrangler d1 migrations apply DB --local",
    "migrate:remote": "pnpm run db:generate && npx wrangler d1 migrations apply DB --remote",
    "deploy": "pnpm run build && cp .assetsignore dist/.assetsignore && pnpm run migrate:remote && npx wrangler deploy",
    "deploy:preview": "pnpm run build && cp .assetsignore dist/.assetsignore && npx wrangler versions upload",
    "cf-typegen": "wrangler types",
    "deps:lockfile": "corepack pnpm install --no-frozen-lockfile && wrangler types",
    "deps:update": "corepack pnpm update --latest && corepack pnpm install --no-frozen-lockfile && wrangler types"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.34",
    "@assistant-ui/react": "^0.14.27",
    "@assistant-ui/react-ai-sdk": "^1.3.41",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/react": "^6.0.1",
    "@base-ui/react": "^1.6.0",
    "@cloudflare/ai-chat": "0.9.3",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@fontsource-variable/inter": "^5.3.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.5.1",
    "@hono/zod-validator": "^0.9.0",
    "@platejs/basic-nodes": "53.0.0",
    "@platejs/code-block": "53.0.0",
    "@platejs/indent": "53.0.0",
    "@platejs/link": "53.3.1",
    "@platejs/list": "53.1.3",
    "@scalar/hono-api-reference": "^0.11.11",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "@tailwindcss/vite": "^4.3.3",
    "agents": "0.17.4",
    "ai": "^7.0.31",
    "assistant-stream": "^0.3.26",
    "astro": "^7.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "0.8.3",
    "hono": "^4.12.31",
    "lucide-react": "^1.25.0",
    "mind-elixir": "5.14.0",
    "platejs": "53.2.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "3.9.2",
    "remark-gfm": "^4.0.1",
    "remeda": "^2.39.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "workers-ai-provider": "^3.3.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "shadcn": "^4.13.1",
    "typescript": "^7.0.2",
    "wrangler": "^4.112.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
