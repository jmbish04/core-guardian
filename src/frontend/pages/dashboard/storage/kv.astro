---
/**
 * KV namespaces — Data Storage detail page.
 *
 * Thin Astro shell over the `<KVTable>` React island.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { KVTable } from "@/components/storage";
---

<BaseLayout title="KV namespaces" description="Every KV namespace and the Workers bound to it.">
  <main class="container mx-auto flex max-w-7xl flex-col gap-8 px-4 py-12">
    <a
      href="/dashboard/storage"
      class="font-mono text-[10px] uppercase tracking-[0.25em] text-muted-foreground hover:text-foreground"
    >
      ← Data Storage
    </a>
    <KVTable client:load />
  </main>
</BaseLayout>
