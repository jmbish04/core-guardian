---
/**
 * Core Guardian — emergency governance control panel.
 *
 * Thin Astro shell over the `<GuardianPanel>` React island, which owns the
 * destructive R2 lifecycle-eviction and Vectorize index-drop flows plus their
 * inline status feedback.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ActionItems, AllowancesPanel, AlertsBoard, GuardianPanel } from "@/components/dashboard";
---

<BaseLayout
  title="Core Guardian"
  description="Emergency governance cockpit: halt infrastructure spend surges by evicting R2 buckets via lifecycle expiration and dropping runaway Vectorize indexes."
>
  <main class="container mx-auto flex max-w-7xl flex-col gap-8 px-4 py-12">
    <header class="flex flex-col gap-2">
      <div class="flex items-center gap-3">
        <span class="text-4xl">🛡️</span>
        <h1 class="text-3xl font-semibold tracking-tight">Core Guardian</h1>
      </div>
      <p class="max-w-3xl text-base text-muted-foreground">
        Emergency controls for infrastructure spend surges. Every action here is
        destructive, executes against the live Cloudflare account, and is
        recorded in the <code class="font-mono">billing_events</code> audit trail.
      </p>
    </header>

    <AlertsBoard client:load />

    <AllowancesPanel client:visible />

    <ActionItems mode="widget" client:load />

    <GuardianPanel client:load />
  </main>
</BaseLayout>
