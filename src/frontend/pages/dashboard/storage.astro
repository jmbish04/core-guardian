---
/**
 * Data Storage dashboard — account-wide storage inventory.
 *
 * Thin Astro shell over the `<StorageDashboard>` React island, which owns the
 * per-product totals, top-5 lists, and navigation into the detail pages.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { StorageDashboard } from "@/components/storage";
---

<BaseLayout
  title="Data Storage"
  description="Account-wide storage inventory: R2 buckets, D1 databases, KV namespaces, data catalogs, and pipelines, with sizes and Worker attribution."
>
  <main class="container mx-auto flex max-w-7xl flex-col gap-8 px-4 py-12">
    <header class="flex flex-col gap-2">
      <div class="flex items-center gap-3">
        <span class="text-4xl">🗄️</span>
        <h1 class="text-3xl font-semibold tracking-tight">Data Storage</h1>
      </div>
      <p class="max-w-3xl text-base text-muted-foreground">
        Every storage resource on the account, with sizes and the Workers bound
        to each. Deletions here are irreversible and recorded in the Core
        Guardian audit trail.
      </p>
    </header>

    <StorageDashboard client:load />
  </main>
</BaseLayout>
