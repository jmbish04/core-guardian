---
/**
 * `/docs` — documentation home / table of contents.
 *
 * A one-screen overview of what Core Guardian is, followed by a linked table of
 * contents for every documentation surface. Deep design and the phased plan
 * live one click away (architecture docs, and the changelog preview) — this page
 * only orients and points.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { shipped, proposed } from "@/lib/changelog";

const shippedCount = shipped().length;
const proposedCount = proposed().length;

const toc: {
  href: string;
  title: string;
  summary: string;
  tag: string;
}[] = [
  {
    href: "/docs/architecture",
    title: "Architecture & System Design",
    summary:
      "How the one Worker fits together — the hourly cron as the only thing that talks to Cloudflare, D1 as materialized state, and the diagrams for the alert lifecycle, information architecture, pricing-scrape pipeline, and the AI circuit breaker. Also the verified-against-the-API findings (no pricing API, R2 has no last-access timestamp) and the defect register.",
    tag: "Start here",
  },
  {
    href: "/changelogs/preview",
    title: "Roadmap / Preview",
    summary: `The full backlog, grouped by PR size, so every required piece is tracked before it is built. ${proposedCount} proposed changes across the P0–P9 phases.`,
    tag: "Plan",
  },
  {
    href: "/changelogs",
    title: "Changelog",
    summary: `Every change that has shipped, newest first — ${shippedCount} so far, each with its scope and deployed version.`,
    tag: "Shipped",
  },
  {
    href: "/openapi.json",
    title: "OpenAPI 3.1 spec",
    summary:
      "The machine-readable contract for the whole API, generated from the Hono + zod route definitions.",
    tag: "API",
  },
  {
    href: "/scalar",
    title: "Scalar API reference",
    summary: "An interactive, modern reference UI over the OpenAPI spec.",
    tag: "API",
  },
  {
    href: "/swagger",
    title: "Swagger UI",
    summary: "The classic try-it-out request explorer over the same spec.",
    tag: "API",
  },
];
---

<BaseLayout
  title="Documentation"
  description="Core Guardian documentation home — what it does, and a table of contents for the architecture docs, roadmap, changelog, and API references."
>
  <div class="container mx-auto max-w-4xl px-4 py-16">
    <!-- Hero -->
    <section class="mb-14">
      <Badge variant="outline" class="mb-4 font-mono text-[11px]">Docs</Badge>
      <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-5xl">Core Guardian</h1>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-muted-foreground">
        A Cloudflare spend-governance cockpit on a single Worker. It watches usage across every
        binding on the account, projects month-end cost against your included allowances, surfaces
        what needs action, and can halt a runaway before it bleeds — evicting an R2 bucket, dropping
        a Vectorize index, or breaking the circuit on AI spend.
      </p>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-muted-foreground">
        One Worker serves Astro SSR pages, a Zod-validated Hono API (with a matching MCP surface),
        and stateful agents. An hourly cron is the only thing that queries Cloudflare's APIs; every
        page reads materialized D1 state.
      </p>
    </section>

    <!-- Table of contents -->
    <section>
      <h2 class="mb-2 text-2xl font-bold tracking-tight">Documentation</h2>
      <p class="mb-6 max-w-3xl text-sm text-muted-foreground">
        Where to find what. Start with the architecture, then the roadmap for what is planned and
        the changelog for what has shipped.
      </p>

      <ol class="flex flex-col gap-3">
        {toc.map((item, i) => (
          <li>
            <a
              href={item.href}
              class="block rounded-xl border border-border/60 bg-background/40 p-5 transition-colors hover:bg-foreground/[0.03]"
            >
              <div class="flex flex-wrap items-center gap-2">
                <span class="font-mono text-xs text-muted-foreground">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <h3 class="text-base font-medium">{item.title}</h3>
                <Badge variant="outline" class="font-mono text-[10px] text-muted-foreground">
                  {item.tag}
                </Badge>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.summary}</p>
            </a>
          </li>
        ))}
      </ol>
    </section>
  </div>
</BaseLayout>
