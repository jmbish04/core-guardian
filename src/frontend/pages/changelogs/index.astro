---
/**
 * `/changelogs` — shipped changes, newest first.
 *
 * Reads the typed registry in `@/lib/changelog`. Proposed / staged work lives on
 * the sibling `/changelogs/preview`; a single entry opens at `/changelogs/[id]`.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { shipped, SIZE_LABEL } from "@/lib/changelog";

const entries = shipped();
---

<BaseLayout
  title="Changelog"
  description="Shipped changes to Core Guardian, newest first."
>
  <div class="container mx-auto max-w-4xl px-4 py-16">
    <header class="mb-10 flex flex-wrap items-end justify-between gap-4">
      <div>
        <Badge variant="outline" class="mb-3 font-mono text-[11px]">Changelog</Badge>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">What shipped</h1>
        <p class="mt-3 max-w-2xl text-sm text-muted-foreground">
          Every change that has landed, newest first. Planned and proposed work is staged on
          <a href="/changelogs/preview" class="text-foreground underline underline-offset-4">the preview</a>.
        </p>
      </div>
      <a
        href="/changelogs/preview"
        class="rounded-lg bg-muted px-4 py-2 text-sm font-semibold transition-colors hover:bg-muted/70"
      >
        View staged previews →
      </a>
    </header>

    <ol class="flex flex-col gap-3">
      {entries.map((e) => (
        <li>
          <a
            href={`/changelogs/${e.id}`}
            class="block rounded-xl border border-border/60 bg-background/40 p-5 transition-colors hover:bg-foreground/[0.03]"
          >
            <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
              <div class="flex flex-wrap items-center gap-2">
                <span class="font-mono text-xs text-muted-foreground">{e.id.split("-")[0]}</span>
                <h2 class="text-base font-medium">{e.title}</h2>
                <Badge
                  variant="outline"
                  class="border-emerald-500/25 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400"
                >
                  Shipped
                </Badge>
                <Badge variant="outline" class="font-mono text-[10px] text-muted-foreground">
                  {e.size}
                </Badge>
              </div>
              <span class="font-mono text-xs text-muted-foreground">
                {e.date}{e.version ? ` · ${e.version}` : ""}
              </span>
            </div>
            <p class="mt-2 text-sm text-muted-foreground">{e.summary}</p>
          </a>
        </li>
      ))}
    </ol>
  </div>
</BaseLayout>
